frr version 10.4.1_git
frr defaults traditional
hostname as100_sat_r1
!
interface eth1
 description to AS100_R1
 ip address 209.1.0.138/30
 ipv6 address 2000:9999:1000:100::2/64
 ipv6 ospf6 area 0
exit
!
interface eth2
 description to AS100_Sat_LAN
 ip address 209.1.3.1/24
 ipv6 address 2000:9999:1000:3::1/64
 ipv6 ospf6 area 0
exit
!
router ospf
 ospf router-id 209.1.3.1
 network 209.1.0.136/30 area 0
 network 209.1.3.0/24 area 0
exit
!
router ospf6
 ospf6 router-id 209.1.3.1
exit
!
