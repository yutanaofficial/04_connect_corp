frr version 10.4.1_git
frr defaults traditional
hostname as9_r0
!
ip prefix-list AS9_networks description My AS9 Networks
ip prefix-list AS9_networks seq 5 permit 109.0.0.0/8 le 24
ip prefix-list AS9_networks seq 10 permit 209.0.0.0/8 le 24
!
ipv6 prefix-list AS9_networks_v6 description My AS9 IPv6 Networks
ipv6 prefix-list AS9_networks_v6 seq 5 permit 2000:9999::/32
!
route-map peers_out permit 10
 match ip address prefix-list AS9_networks
 set community 9:100 additive
 set metric 10
exit
!
route-map peers_out permit 15
 match ipv6 address prefix-list AS9_networks_v6
 set community 9:100 additive
 set metric 10
exit
!
route-map peers_out permit 20
 match as-path transit_as
exit
!
route-map peers_out deny 999
exit
!
route-map peers_in permit 10
exit
!
ip route 109.1.0.0/16 blackhole 254
ip route 209.0.0.0/16 blackhole 254
ip route 209.1.0.0/22 109.1.0.2
ip route 109.0.0.0/24 blackhole 254
ipv6 route 2000:9999::/32 blackhole 254
ipv6 route 2000:9999:1000::/48 2000:9999:9:eeee::1
!
interface eth1
 description to AS9_H1
 ip address 209.0.0.1/30
 ip ospf area 0
 ip ospf passive
 ipv6 address 2000:9999:9:ffff::1/64
 ipv6 ospf6 area 0
 ipv6 ospf6 passive
exit
!
interface eth2
 description connection to AS7
 ip address 107.1.0.2/30
exit
!
interface eth3
 description connection to AS9
 ip address 108.1.0.2/30
exit
!
interface eth4
 description connection to AS100
 ip address 109.1.0.1/30
 ipv6 address 2000:9999:9:eeee::1/64
exit
!
interface lo
 description AS9 R0 Loopback
 ip address 109.0.0.0/32
 ip ospf area 0
 ip ospf passive
 ipv6 address 2000:9999:9::/128
 ipv6 ospf6 area 0
 ipv6 ospf6 passive
exit
!
router bgp 9
 bgp router-id 109.0.0.0
 bgp log-neighbor-changes
 neighbor 107.1.0.1 remote-as 7
 neighbor 107.1.0.1 description AS7
 neighbor 108.1.0.1 remote-as 8
 neighbor 108.1.0.1 description AS8
 !
 address-family ipv4 unicast
  network 109.0.0.0/24
  network 109.1.0.0/16
  network 209.0.0.0/16
  neighbor 107.1.0.1 next-hop-self
  neighbor 107.1.0.1 route-map peers_in in
  neighbor 107.1.0.1 route-map peers_out out
  neighbor 108.1.0.1 next-hop-self
  neighbor 108.1.0.1 route-map peers_in in
  neighbor 108.1.0.1 route-map peers_out out
 exit-address-family
 !
 address-family ipv6 unicast
  network 2000:9999::/32
  neighbor 107.1.0.1 activate
  neighbor 107.1.0.1 next-hop-self
  neighbor 107.1.0.1 route-map peers_in in
  neighbor 107.1.0.1 route-map peers_out out
  neighbor 108.1.0.1 activate
  neighbor 108.1.0.1 next-hop-self
  neighbor 108.1.0.1 route-map peers_in in
  neighbor 108.1.0.1 route-map peers_out out
 exit-address-family
exit
!
router ospf
 ospf router-id 109.0.0.0
 redistribute connected metric-type 1
exit
!
router ospf6
 ospf6 router-id 109.0.0.0
 redistribute connected metric-type 1
exit
!
